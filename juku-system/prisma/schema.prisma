generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          String   // admin / teacher / student
  name          String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  student  Student?
  teacher  Teacher?
  alerts   Alert[]

  @@map("users")
}

model Student {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  graduationYear Int      @map("graduation_year") // 卒業年度（例: 2027）
  schoolName     String   @map("school_name")
  parentName     String   @map("parent_name")
  parentPhone    String   @map("parent_phone")
  parentEmail    String   @map("parent_email")
  enrollmentDate DateTime @map("enrollment_date")
  status         String   @default("active") // active / inactive / withdrawn
  notes          String   @default("")
  // 追加項目
  furigana               String    @default("")
  gender                 String    @default("") // male / female / other
  birthDate              DateTime? @map("birth_date")
  mobilePhone            String    @default("") @map("mobile_phone")
  postalCode             String    @default("") @map("postal_code")
  address                String    @default("")
  referrer               String    @default("") // 塾の紹介者
  track                  String    @default("") // liberal_arts / science / both
  firstChoiceSchool      String    @default("") @map("first_choice_school")
  desiredFaculty         String    @default("") @map("desired_faculty")
  examSubjects           String    @default("[]") @map("exam_subjects") // JSON array
  considerRecommendation Boolean   @default(false) @map("consider_recommendation")
  eikenPlan              String    @default("") @map("eiken_plan")
  campus                 String    @default("") // shuri / naha
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user                User                 @relation(fields: [userId], references: [id])
  progressRecords     ProgressRecord[]
  tasks               Task[]
  learningGoals       LearningGoal[]
  bigGoals            BigGoal[]
  meetings            Meeting[]
  routineTasks        RoutineTask[]
  assignments         StudentAssignment[]
  studySchedule       StudyScheduleDay[]
  mockExamResults     MockExamResult[]
  studyRoomSessions   StudyRoomSession[]
  pointTransactions   PointTransaction[]

  @@map("students")
}

model StudyRoomSession {
  id            String    @id @default(uuid())
  studentId     String    @map("student_id")
  campus        String    // shuri / naha
  seatType      String    @default("booth") @map("seat_type") // booth / table
  checkInAt     DateTime  @map("check_in_at")
  checkOutAt    DateTime? @map("check_out_at")
  autoCheckedOut Boolean  @default(false) @map("auto_checked_out")
  pointAwarded  Boolean   @default(false) @map("point_awarded")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, checkOutAt])
  @@index([campus, checkOutAt])
  @@map("study_room_sessions")
}

model Campus {
  id         String   @id @default(uuid())
  code       String   @unique // shuri / naha / ...
  label      String   // 首里校舎 / 那覇校舎 / ...
  closeTime  String   @default("21:00") @map("close_time") // HH:mm JST
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("campuses")
}

model StudyRoomConfig {
  id             String   @id @default(uuid())
  campus         String   @unique // shuri / naha
  boothCapacity  Int      @default(10) @map("booth_capacity")
  tableCapacity  Int      @default(0)  @map("table_capacity")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("study_room_configs")
}

model PointTransaction {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  delta     Int      // +1 付与 / -N 交換
  reason    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("point_transactions")
}

model MockExamResult {
  id                String   @id @default(uuid())
  studentId         String   @map("student_id")
  examName          String   @map("exam_name")
  examDate          DateTime @map("exam_date")
  gradeLevel        String   @map("grade_level") // high1 / high2 / high3 / ronin
  overallDeviation  Float?   @map("overall_deviation")
  overallScore      Int?     @map("overall_score")
  schoolRank        Int?     @map("school_rank")
  judgment          String   @default("") // A / B / C / D / E
  subjects          String   @default("[]") // JSON: [{subject, deviation, score}]
  notes             String   @default("")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("mock_exam_results")
}

model Teacher {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  subjects       String   // JSON array stored as string
  employmentType String   @map("employment_type") // full_time / part_time
  phone          String
  status         String   @default("active") // active / inactive
  // 追加項目
  universityFaculty String   @default("") @map("university_faculty") // 大学学部
  department        String   @default("")                              // 学科
  graduationYear    Int?     @map("graduation_year")                   // 卒業年度
  examSubjectsTaken String   @default("[]") @map("exam_subjects_taken") // 受験した科目 JSON
  emergencyContact  String   @default("") @map("emergency_contact")    // 緊急連絡先
  universityClub    String   @default("") @map("university_club")      // 大学での部活
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user                User                 @relation(fields: [userId], references: [id])
  progressRecords     ProgressRecord[]
  tasks               Task[]
  shifts              Shift[]
  meetings            Meeting[]
  attendances         Attendance[]
  routineTasks        RoutineTask[]
  shiftTemplateDays   ShiftTemplateDay[]
  assignments         StudentAssignment[]

  @@map("teachers")
}

model StudentAssignment {
  id        String   @id @default(uuid())
  teacherId String   @map("teacher_id")
  studentId String   @map("student_id")
  createdAt DateTime @default(now()) @map("created_at")

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([teacherId, studentId])
  @@map("student_assignments")
}

model ProgressRecord {
  id              String   @id @default(uuid())
  studentId       String   @map("student_id")
  teacherId       String   @map("teacher_id")
  subject         String
  date            DateTime
  material        String   // 教材名
  topic           String   @default("") // 学習内容
  pagesCompleted  Int      @map("pages_completed") // 今回進めたページ数
  goalId          String?  @map("goal_id") // 紐づく学習目標（任意）
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  student Student        @relation(fields: [studentId], references: [id])
  teacher Teacher        @relation(fields: [teacherId], references: [id])
  goal    LearningGoal?  @relation(fields: [goalId], references: [id])

  @@map("progress_records")
}

model Task {
  id              String    @id @default(uuid())
  studentId       String?   @map("student_id")
  teacherId       String    @map("teacher_id")
  subject         String
  title           String
  description     String    @default("")
  dueDate         DateTime  @map("due_date")
  status          String    @default("pending") // pending / in_progress / completed / overdue
  type            String    @default("通常") // 通常 / 要引き継ぎ / 面談
  meetingDateTime DateTime? @map("meeting_datetime") // 面談タスクの予定日時
  meetingAlerted  Boolean   @default(false) @map("meeting_alerted")
  overdueAlerted  Boolean   @default(false) @map("overdue_alerted")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  student Student? @relation(fields: [studentId], references: [id])
  teacher Teacher  @relation(fields: [teacherId], references: [id])

  @@map("tasks")
}

model Attendance {
  id        String    @id @default(uuid())
  teacherId String    @map("teacher_id")
  clockIn   DateTime  @map("clock_in")
  clockOut  DateTime? @map("clock_out")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@map("attendances")
}

// 講師ごとの週次シフトテンプレート（曜日単位で時刻を個別に設定）
model ShiftTemplateDay {
  id        String   @id @default(uuid())
  teacherId String   @map("teacher_id")
  weekday   Int      // 0=日, 1=月, ..., 6=土
  startTime String   @map("start_time") // HH:mm
  endTime   String   @map("end_time")   // HH:mm
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, weekday])
  @@map("shift_template_days")
}

model RoutineTask {
  id          String   @id @default(uuid())
  teacherId   String   @map("teacher_id")
  studentId   String?  @map("student_id")
  subject     String
  title       String
  description String   @default("")
  type        String   @default("通常") // 通常 / 要引き継ぎ / 面談
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  teacher Teacher  @relation(fields: [teacherId], references: [id])
  student Student? @relation(fields: [studentId], references: [id])

  @@map("routine_tasks")
}

model Alert {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // task_overdue / shift_reminder / progress_warning / general
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("alerts")
}

model Shift {
  id                    String   @id @default(uuid())
  teacherId             String   @map("teacher_id")
  date                  DateTime
  startTime             String   @map("start_time") // HH:mm format
  endTime               String   @map("end_time")   // HH:mm format
  status                String   @default("scheduled") // scheduled / confirmed / cancelled
  notes                 String   @default("")
  noShowAlerted         Boolean  @default(false) @map("no_show_alerted")
  forgotClockOutAlerted Boolean  @default(false) @map("forgot_clock_out_alerted")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@map("shifts")
}

model Meeting {
  id              String    @id @default(uuid())
  studentId       String    @map("student_id")
  teacherId       String    @map("teacher_id")
  date            DateTime
  durationMinutes Int?      @map("duration_minutes") // 面談時間（分）
  type            String?   // 定期面談 / 進路相談 / 学習相談 / 保護者面談 / その他
  status          String    @default("conducted") // conducted / rescheduled
  content          String    // 面談内容
  parentComment    String    @default("") @map("parent_comment") // 親御さんへの共有コメント
  goalsSnapshot    String    @default("[]") @map("goals_snapshot")    // JSON: 面談時点の大目標/指標スナップショット
  progressSnapshot String    @default("[]") @map("progress_snapshot") // JSON: 前回面談〜今回の学習進捗一覧
  nextMeetingDate  DateTime? @map("next_meeting_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@map("meetings")
}

model LearningGoal {
  id           String    @id @default(uuid())
  studentId    String    @map("student_id")
  bigGoalId    String?   @map("big_goal_id")
  subject      String    // 科目
  materialName String    @map("material_name")   // 教材名
  targetPages  Int       @map("target_pages")    // 目標ページ数
  startDate    DateTime? @map("start_date")      // 週の開始日
  dueDate      DateTime  @map("due_date")        // 週の終了日（完了期限）
  status       String    @default("in_progress") // in_progress / completed
  notes        String    @default("")
  paceAlerted  Boolean   @default(false) @map("pace_alerted")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  student         Student          @relation(fields: [studentId], references: [id])
  bigGoal         BigGoal?         @relation(fields: [bigGoalId], references: [id])
  progressRecords ProgressRecord[]

  @@map("learning_goals")
}

model BigGoal {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  subject      String
  materialName String   @map("material_name")
  targetPages  Int      @map("target_pages")
  startDate    DateTime @map("start_date")
  dueDate      DateTime @map("due_date")
  status       String   @default("in_progress") // in_progress / completed
  notes        String   @default("")
  paceAlerted  Boolean  @default(false) @map("pace_alerted")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student      Student        @relation(fields: [studentId], references: [id])
  weeklyGoals  LearningGoal[]

  @@map("big_goals")
}

model Article {
  id          String   @id @default(uuid())
  title       String
  body        String   // markdown
  audience    String   @default("both") // student / teacher / both
  category    String   @default("その他") // システム使い方 / 塾ルール / 事務手続き / その他
  images      String   @default("[]") // JSON array of {url, name}
  publishedAt DateTime @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("articles")
}

model School {
  id        String        @id @default(uuid())
  name      String        @unique
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  events    SchoolEvent[]

  @@map("schools")
}

model SchoolEvent {
  id          String   @id @default(uuid())
  schoolId    String   @map("school_id")
  title       String
  description String   @default("")
  startDate   DateTime @map("start_date")
  endDate     DateTime? @map("end_date")
  eventType   String   @default("その他") @map("event_type") // 試験 / 文化祭 / 体育祭 / 修学旅行 / その他
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("school_events")
}

model StudyScheduleDay {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  weekday   Int      // 0=日 ... 6=土
  hours     Float    @default(0) // 後方互換用（slotsから自動計算）
  slots     String   @default("[]") // JSON: [{subject: string, minutes: number}]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, weekday])
  @@map("study_schedule_days")
}
