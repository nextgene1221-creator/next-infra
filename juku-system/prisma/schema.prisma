generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          String   // admin / teacher / student
  name          String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  student  Student?
  teacher  Teacher?
  alerts   Alert[]

  @@map("users")
}

model Student {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  graduationYear Int      @map("graduation_year") // 卒業年度（例: 2027）
  schoolName     String   @map("school_name")
  parentName     String   @map("parent_name")
  parentPhone    String   @map("parent_phone")
  parentEmail    String   @map("parent_email")
  enrollmentDate DateTime @map("enrollment_date")
  status         String   @default("active") // active / inactive / withdrawn
  notes          String   @default("")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id])
  progressRecords  ProgressRecord[]
  tasks            Task[]
  learningGoals    LearningGoal[]
  meetings         Meeting[]
  routineTasks     RoutineTask[]

  @@map("students")
}

model Teacher {
  id             String   @id @default(uuid())
  userId         String   @unique @map("user_id")
  subjects       String   // JSON array stored as string
  employmentType String   @map("employment_type") // full_time / part_time
  phone          String
  status         String   @default("active") // active / inactive
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user             User              @relation(fields: [userId], references: [id])
  progressRecords  ProgressRecord[]
  tasks            Task[]
  shifts           Shift[]
  meetings         Meeting[]
  attendances      Attendance[]
  routineTasks     RoutineTask[]
  shiftTemplate    ShiftTemplate?

  @@map("teachers")
}

model ProgressRecord {
  id              String   @id @default(uuid())
  studentId       String   @map("student_id")
  teacherId       String   @map("teacher_id")
  subject         String
  date            DateTime
  material        String   // 教材名
  topic           String   @default("") // 学習内容
  pagesCompleted  Int      @map("pages_completed") // 今回進めたページ数
  goalId          String?  @map("goal_id") // 紐づく学習目標（任意）
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  student Student        @relation(fields: [studentId], references: [id])
  teacher Teacher        @relation(fields: [teacherId], references: [id])
  goal    LearningGoal?  @relation(fields: [goalId], references: [id])

  @@map("progress_records")
}

model Task {
  id              String    @id @default(uuid())
  studentId       String?   @map("student_id")
  teacherId       String    @map("teacher_id")
  subject         String
  title           String
  description     String    @default("")
  dueDate         DateTime  @map("due_date")
  status          String    @default("pending") // pending / in_progress / completed / overdue
  type            String    @default("通常") // 通常 / 要引き継ぎ / 面談
  meetingDateTime DateTime? @map("meeting_datetime") // 面談タスクの予定日時
  meetingAlerted  Boolean   @default(false) @map("meeting_alerted")
  overdueAlerted  Boolean   @default(false) @map("overdue_alerted")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  student Student? @relation(fields: [studentId], references: [id])
  teacher Teacher  @relation(fields: [teacherId], references: [id])

  @@map("tasks")
}

model Attendance {
  id        String    @id @default(uuid())
  teacherId String    @map("teacher_id")
  clockIn   DateTime  @map("clock_in")
  clockOut  DateTime? @map("clock_out")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@map("attendances")
}

model ShiftTemplate {
  id        String   @id @default(uuid())
  teacherId String   @unique @map("teacher_id")
  weekdays  String   // カンマ区切り "1,3,5" (0=日 ... 6=土)
  startTime String   @map("start_time") // HH:mm
  endTime   String   @map("end_time")   // HH:mm
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@map("shift_templates")
}

model RoutineTask {
  id          String   @id @default(uuid())
  teacherId   String   @map("teacher_id")
  studentId   String?  @map("student_id")
  subject     String
  title       String
  description String   @default("")
  type        String   @default("通常") // 通常 / 要引き継ぎ / 面談
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  teacher Teacher  @relation(fields: [teacherId], references: [id])
  student Student? @relation(fields: [studentId], references: [id])

  @@map("routine_tasks")
}

model Alert {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String   // task_overdue / shift_reminder / progress_warning / general
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("alerts")
}

model Shift {
  id                    String   @id @default(uuid())
  teacherId             String   @map("teacher_id")
  date                  DateTime
  startTime             String   @map("start_time") // HH:mm format
  endTime               String   @map("end_time")   // HH:mm format
  status                String   @default("scheduled") // scheduled / confirmed / cancelled
  notes                 String   @default("")
  noShowAlerted         Boolean  @default(false) @map("no_show_alerted")
  forgotClockOutAlerted Boolean  @default(false) @map("forgot_clock_out_alerted")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@map("shifts")
}

model Meeting {
  id              String    @id @default(uuid())
  studentId       String    @map("student_id")
  teacherId       String    @map("teacher_id")
  date            DateTime
  durationMinutes Int?      @map("duration_minutes") // 面談時間（分）
  type            String?   // 定期面談 / 進路相談 / 学習相談 / 保護者面談 / その他
  content         String    // 面談内容
  nextMeetingDate DateTime? @map("next_meeting_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@map("meetings")
}

model LearningGoal {
  id           String   @id @default(uuid())
  studentId    String   @map("student_id")
  subject      String   // 科目
  materialName String   @map("material_name")   // 教材名
  targetPages  Int      @map("target_pages")    // 目標ページ数
  dueDate      DateTime @map("due_date")        // 完了期限日
  status       String   @default("in_progress") // in_progress / completed
  notes        String   @default("")
  paceAlerted  Boolean  @default(false) @map("pace_alerted")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student         Student          @relation(fields: [studentId], references: [id])
  progressRecords ProgressRecord[]

  @@map("learning_goals")
}
